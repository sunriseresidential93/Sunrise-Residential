---
interface Props {
  variant?: 'light' | 'dark';
}
const { variant = 'light' } = Astro.props;

const textBase = variant === 'dark' ? 'text-white/80' : 'text-gray-700';
const labelColor = variant === 'dark' ? 'text-sunrise-gold' : 'text-sunrise-navy';
const iconColor = variant === 'dark' ? 'text-sunrise-gold' : 'text-sunrise-gold';
const linkHover = variant === 'dark' ? 'hover:text-sunrise-gold' : 'hover:text-sunrise-gold';
---

<address class={`not-italic space-y-4 text-sm ${textBase}`}>
  <div class="flex gap-3 items-start">
    <svg class={`w-5 h-5 mt-0.5 shrink-0 ${iconColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
    </svg>
    <div>
      <p class={`font-semibold ${labelColor} text-xs uppercase tracking-wide mb-0.5`}>Address</p>
      <p>6371 Washington St NE<br/>Fridley, MN 55432</p>
    </div>
  </div>

  <div class="flex gap-3 items-start">
    <svg class={`w-5 h-5 mt-0.5 shrink-0 ${iconColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
    </svg>
    <div>
      <p class={`font-semibold ${labelColor} text-xs uppercase tracking-wide mb-0.5`}>Phone</p>
      <a href="tel:6124069257" class={`transition-colors ${linkHover}`}>612-406-9257</a>
    </div>
  </div>

  <div class="flex gap-3 items-start">
    <svg class={`w-5 h-5 mt-0.5 shrink-0 ${iconColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
    </svg>
    <div>
      <p class={`font-semibold ${labelColor} text-xs uppercase tracking-wide mb-0.5`}>Email</p>
      <a href="mailto:sunriseresidentialllc@gmail.com" class={`transition-colors break-all ${linkHover}`}>
        sunriseresidentialllc@gmail.com
      </a>
    </div>
  </div>

  <div class="flex gap-3 items-start">
    <svg class={`w-5 h-5 mt-0.5 shrink-0 ${iconColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <div>
      <p class={`font-semibold ${labelColor} text-xs uppercase tracking-wide mb-0.5`}>Hours</p>
      <p>Mon – Fri: 9:00 AM – 5:00 PM</p>
      <p>After hours: 612-406-9257</p>
    </div>
  </div>
</address>
