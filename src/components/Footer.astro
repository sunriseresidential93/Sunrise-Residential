---
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Who We Serve', href: '/who-we-serve' },
  { label: 'Licensing & Payment', href: '/licensing-payment' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="bg-sunrise-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand column -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div>
            <p class="font-heading font-semibold text-sunrise-gold leading-tight">Sunrise Residential LLC</p>
            <p class="text-sunrise-lavender text-xs leading-tight">Licensed Assisted Living Facility</p>
          </div>
        </div>
        <p class="text-white/70 text-sm leading-relaxed">
          High-quality, compassionate, personalized long-term care in Fridley, Minnesota.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-heading font-semibold text-sunrise-gold mb-4 text-base">Quick Links</h3>
        <ul class="space-y-2">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="text-white/80 hover:text-sunrise-gold text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="font-heading font-semibold text-sunrise-gold mb-4 text-base">Contact Us</h3>
        <address class="not-italic space-y-3 text-sm text-white/80">
          <p class="flex gap-2 items-start">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-sunrise-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            6371 Washington St NE<br/>Fridley, MN 55432
          </p>
          <p class="flex gap-2 items-center">
            <svg class="w-4 h-4 shrink-0 text-sunrise-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:6124069257" class="hover:text-sunrise-gold transition-colors">612-406-9257</a>
          </p>
          <p class="flex gap-2 items-center">
            <svg class="w-4 h-4 shrink-0 text-sunrise-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:sunriseresidentialllc@gmail.com" class="hover:text-sunrise-gold transition-colors break-all">
              sunriseresidentialllc@gmail.com
            </a>
          </p>
          <div class="pt-1">
            <p class="font-semibold text-white/90 mb-1">Office Hours</p>
            <p>Mon – Fri: 9:00 AM – 5:00 PM</p>
            <p>After hours: 612-406-9257</p>
          </div>
        </address>
      </div>

    </div>

    <div class="mt-10 pt-6 border-t border-white/20 flex flex-col sm:flex-row items-center justify-between gap-2 text-white/50 text-xs">
      <p>&copy; {currentYear} Sunrise Residential LLC. All rights reserved.</p>
      <p>Licensed Assisted Living Facility — Fridley, Minnesota</p>
    </div>
  </div>
</footer>
