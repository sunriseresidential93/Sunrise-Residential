---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureCard from '../components/FeatureCard.astro';

const features = [
  {
    title: '24-Hour Awake Staff',
    description: 'Our team is on-site and alert around the clock to ensure residents are always safe and cared for.',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Home-Like Environment',
    description: 'A comfortable, warm residential setting in an established Fridley neighborhood — not an institution.',
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  },
  {
    title: 'Medication Management',
    description: 'Trained staff assist with medication administration and tracking to keep residents healthy and on schedule.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    title: 'Daily Living Support',
    description: 'Comprehensive assistance with bathing, grooming, meals, housekeeping, and all daily activities.',
    icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
  },
  {
    title: 'Personalized Attention',
    description: 'With a small licensed capacity of five residents, every individual receives focused, respectful care.',
    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
  },
  {
    title: 'Social & Recreational Activities',
    description: 'Enriching programming designed to promote mental stimulation, social engagement, and well-being.',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
  },
];
---

<BaseLayout
  title="Home"
  description="Sunrise Residential LLC offers high-quality, compassionate, personalized long-term care in Fridley, Minnesota. A licensed home-based assisted living facility with 24-hour staff."
>
  <!-- Hero Section -->
  <section class="relative bg-sunrise-navy min-h-[85vh] flex items-center" aria-labelledby="hero-heading">
    <div class="absolute inset-0 bg-linear-to-br from-sunrise-navy via-sunrise-navy to-[#0f1a42] opacity-95"></div>
    <div class="absolute bottom-0 left-0 right-0 h-1 bg-sunrise-gold"></div>
    <div class="absolute top-0 right-0 w-64 h-64 rounded-full bg-sunrise-gold/5 -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-48 h-48 rounded-full bg-sunrise-lavender/10 translate-y-1/2 -translate-x-1/2"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
      <p class="text-sunrise-gold font-semibold tracking-widest text-sm uppercase mb-4">Fridley, Minnesota</p>
      <h1 id="hero-heading" class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Compassionate,<br class="hidden sm:block"/>
        <span class="text-sunrise-gold">Personalized</span> Long-Term Care
      </h1>
      <p class="text-sunrise-lavender text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        A comfortable assisted living home in Fridley, Minnesota. Where every resident is known by name, and treated like family.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="content-center inline-block bg-sunrise-gold text-sunrise-navy font-bold px-8 py-4 rounded-lg text-base hover:brightness-110 transition-all shadow-lg"
        >
          Contact Us Today
        </a>
        <a
          href="/services"
          class="content-center inline-block border-2 border-white/40 text-white font-semibold px-8 py-4 rounded-lg text-base hover:border-sunrise-gold hover:text-sunrise-gold transition-colors"
        >
          View Our Services
        </a>
      </div>
    </div>
  </section>

  <!-- Quick Intro Block -->
  <section class="py-16 px-4 bg-white" aria-labelledby="intro-heading">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-block bg-sunrise-lavender/30 text-sunrise-navy px-4 py-1 rounded-full text-sm font-semibold mb-4">
        About Us
      </div>
      <h2 id="intro-heading" class="font-heading text-3xl sm:text-4xl font-bold text-sunrise-navy mb-6">
        A Place to Call Home
      </h2>
      <div class="text-gray-600 text-base sm:text-lg leading-relaxed space-y-4 max-w-3xl mx-auto">
        <p>
          Sunrise Residential LLC offers high-quality, compassionate, personalized long-term care. A comfortable, clean, well-resourced facility — and we ensure our programming and staffing provide excellent care every day.
        </p>
        <p>
          We operate a home-based, four-bed residential facility providing exceptional, personalized care for our residents in a safe, welcoming neighborhood.
        </p>
      </div>
      <a href="/about" class="inline-block mt-8 text-sunrise-navy font-semibold border-b-2 border-sunrise-gold pb-0.5 hover:text-sunrise-gold transition-colors">
        Learn more about us &rarr;
      </a>
    </div>
  </section>

  <!-- Features Strip -->
  <section class="py-16 px-4 bg-gray-50" aria-labelledby="features-heading">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 id="features-heading" class="font-heading text-3xl sm:text-4xl font-bold text-sunrise-navy mb-3">
          What Sets Us Apart
        </h2>
        <p class="text-gray-500 max-w-xl mx-auto">
          We combine skilled, compassionate care with the warmth of a true home environment.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map(f => (
          <FeatureCard title={f.title} description={f.description} icon={f.icon} />
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Info Bar -->
  <section class="bg-sunrise-navy py-10 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 text-center sm:text-left">
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-3">
          <svg class="w-6 h-6 text-sunrise-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <div>
            <p class="text-sunrise-gold text-xs uppercase font-semibold tracking-wide">Address</p>
            <p class="text-white/80 text-sm">6371 Washington St NE<br/>Fridley, MN 55432</p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-3">
          <svg class="w-6 h-6 text-sunrise-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <div>
            <p class="text-sunrise-gold text-xs uppercase font-semibold tracking-wide">Phone</p>
            <a href="tel:6124069257" class="text-white/80 text-sm hover:text-sunrise-gold transition-colors">612-406-9257</a>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-3">
          <svg class="w-6 h-6 text-sunrise-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <div>
            <p class="text-sunrise-gold text-xs uppercase font-semibold tracking-wide">Email</p>
            <a href="mailto:sunriseresidentialllc@gmail.com" class="text-white/80 text-sm hover:text-sunrise-gold transition-colors break-all">
              sunriseresidentialllc@gmail.com
            </a>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-3">
          <svg class="w-6 h-6 text-sunrise-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/>
          </svg>
          <div>
            <p class="text-sunrise-gold text-xs uppercase font-semibold tracking-wide">Website</p>
            <p class="text-white/80 text-sm">www.sunriseresidentialllc.com</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 px-4 bg-white text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-heading text-3xl font-bold text-sunrise-navy mb-4">Ready to Learn More?</h2>
      <p class="text-gray-600 mb-8">
        We'd love to answer your questions and help you find the right care for your loved one. Reach out to our team today.
      </p>
      <a
        href="/contact"
        class="inline-block bg-sunrise-navy text-white font-bold px-10 py-4 rounded-lg hover:brightness-110 transition-all shadow-md"
      >
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
