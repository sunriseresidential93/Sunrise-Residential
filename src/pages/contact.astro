---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactInfo from '../components/ContactInfo.astro';
---

<BaseLayout
  title="Contact"
  description="Contact Sunrise Residential LLC — a licensed assisted living facility in Fridley, Minnesota. Call 612-406-9257 or send us a message."
>
  <PageHeader
    title="Contact Us"
    subtitle="We'd love to hear from you. Reach out to our team with any questions or to schedule a visit."
  />

  <section class="py-16 px-4 bg-white" aria-labelledby="contact-heading">
    <div class="max-w-6xl mx-auto">
      <h2 id="contact-heading" class="sr-only">Contact Information and Form</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Contact Details -->
        <div>
          <h3 class="font-heading text-2xl font-bold text-sunrise-navy mb-2">Get in Touch</h3>
          <div class="w-12 h-1 bg-sunrise-gold rounded-full mb-6"></div>
          <p class="text-gray-600 mb-8 leading-relaxed">
            Whether you have questions about our services, want to learn more about availability, or are ready to start the conversation about care for a loved one — we're here to help.
          </p>
          <ContactInfo variant="light" />

          <!-- Office Hours callout -->
          <div class="mt-8 bg-sunrise-navy rounded-xl p-6 text-white">
            <h4 class="font-heading font-semibold text-sunrise-gold mb-3">Office Hours</h4>
            <div class="space-y-2 text-white/80 text-sm">
              <div class="flex justify-between">
                <span>Monday – Friday</span>
                <span class="font-semibold text-white">9:00 AM – 5:00 PM</span>
              </div>
              <div class="flex justify-between border-t border-white/10 pt-2 mt-2">
                <span>After Hours</span>
                <a href="tel:6124069257" class="font-semibold text-sunrise-gold hover:brightness-110 transition-all">612-406-9257</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
          <h3 class="font-heading text-2xl font-bold text-sunrise-navy mb-2">Send Us a Message</h3>
          <div class="w-12 h-1 bg-sunrise-gold rounded-full mb-6"></div>

          <form
            name="contact"
            method="POST"
            action="/contact?sent=true"
            class="space-y-5"
            aria-label="Contact form"
          >
            <div>
              <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">
                Full Name <span class="text-red-500" aria-label="required">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-sunrise-navy focus:border-transparent transition-all bg-white"
                placeholder="Your full name"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1">
                Phone Number
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-sunrise-navy focus:border-transparent transition-all bg-white"
                placeholder="(612) 000-0000"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">
                Email Address <span class="text-red-500" aria-label="required">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-sunrise-navy focus:border-transparent transition-all bg-white"
                placeholder="you@example.com"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">
                Message <span class="text-red-500" aria-label="required">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-sunrise-navy focus:border-transparent transition-all bg-white resize-y"
                placeholder="Tell us how we can help you..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-sunrise-navy text-white font-bold py-4 px-6 rounded-lg hover:brightness-110 transition-all shadow-md text-sm tracking-wide"
            >
              Send Message
            </button>

            <p class="text-gray-400 text-xs text-center">
              Fields marked <span class="text-red-400">*</span> are required.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- Map / Address emphasis -->
  <section class="py-10 px-4 bg-sunrise-lavender/20">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sunrise-navy font-semibold text-sm uppercase tracking-wide mb-2">Our Location</p>
      <p class="font-heading text-2xl font-bold text-sunrise-navy mb-1">6371 Washington St NE</p>
      <p class="text-gray-600 text-lg mb-6">Fridley, MN 55432</p>
      <a
        href="https://maps.google.com/?q=6371+Washington+St+NE+Fridley+MN+55432"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-sunrise-navy text-white font-semibold px-6 py-3 rounded-lg hover:brightness-110 transition-all text-sm"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        View on Google Maps
      </a>
    </div>
  </section>
</BaseLayout>
